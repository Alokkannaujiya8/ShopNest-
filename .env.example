# =========================================================================
# ShopNest E-Commerce Management System - Environment Variables Example File
# =========================================================================

# Database Connection Settings
DefaultConnection="Server=YOUR_SERVER_NAME;Database=ShopNestDb;Trusted_Connection=True;TrustServerCertificate=True;"

# JWT Security Configurations
JWT_SECRET_KEY="YOUR_SUPER_SECRET_COMPLEX_SECURITY_JWT_SIGNING_KEY_32_CHARS"
JWT_ISSUER="ShopNestAPI"
JWT_AUDIENCE="ShopNestClients"
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# Caching & Queue Configurations
REDIS_CONNECTION_STRING="localhost:6379"
RABBITMQ_HOST="localhost"
ELASTICSEARCH_URL="http://localhost:9200"

# Cloudinary Media Assets Configurations
CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME"
CLOUDINARY_API_KEY="YOUR_API_KEY"
CLOUDINARY_API_SECRET="YOUR_API_SECRET"

# Stripe Payment Integrations
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email SMTP Settings
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-specific-password"
SMTP_FROM_EMAIL="noreply@shopnest.com"
SMTP_FROM_NAME="ShopNest Customer Support"

# Application General Configurations
ASPNETCORE_ENVIRONMENT="Development"
APPLICATION_PORT=5000
ANGULAR_CLIENT_URL="http://localhost:4200"
